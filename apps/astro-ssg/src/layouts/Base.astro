---
import { joinBaseUrl } from '../utils/tools.js';
---
<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Astro SSG</title>
  <style>
    :global(*) {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: system-ui, sans-serif;
    }
    .app-container {
      min-height: 100vh;
      background: #e9e4f0;
      padding: 30px 20px;
    }
    .nav {
      display: flex;
      gap: 20px;
      margin-bottom: 30px;
      font-size: 18px;
    }
    .nav a {
      text-decoration: none;
      color: #1677ff;
      font-weight: 500;
      cursor: pointer;
    }
    .nav a:hover {
      color: #0958d9;
    }
    .page-content {
      max-width: 800px;
      margin: 0 auto;
    }
    :global(.error-tip) {
      margin-top: 20px;
      color: #ff4d4f;
      font-weight: 500;
    }
    :global(.user-list) {
      margin-top: 20px;
      list-style: none;
    }
    :global(.user-list li) {
      padding: 10px 0;
      border-bottom: 1px solid #ccc;
    }
    :global(.demo-img) {
      max-width: 100%;
      margin-top: 20px;
      border-radius: 8px;
    }
  </style>
</head>
<body>
  <div class="app-container">
    <nav class="nav">
      <a href={joinBaseUrl('/')} aria-current={Astro.url.pathname === '/' ? 'page' : undefined}>Home</a>
      <a href={joinBaseUrl('/about')} aria-current={Astro.url.pathname === '/about' ? 'page' : undefined}>About</a>
      <a href={joinBaseUrl('/link')} aria-current={Astro.url.pathname === '/link' ? 'page' : undefined}>Link</a>
    </nav>
    <div class="page-content">
      <slot />
    </div>
  </div>
</body>
</html>